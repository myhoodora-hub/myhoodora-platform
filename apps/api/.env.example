# ============================================================
#  MyHoodora Backend — Environment Variables
# ============================================================

# ────────────────────────────────────────────────
# Application
# ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ────────────────────────────────────────────────
# MongoDB
# ────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/myhoodora

# ────────────────────────────────────────────────
# Firebase Admin SDK
# Either point to a service-account JSON file …
# ────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"

# … or provide the path to the downloaded service-account file
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/serviceAccountKey.json

# ────────────────────────────────────────────────
# JWT / Auth (optional — used if you issue your own tokens)
# ────────────────────────────────────────────────
JWT_SECRET=replace_with_a_strong_random_secret
JWT_EXPIRES_IN=7d

# ────────────────────────────────────────────────
# CORS
# ────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173
